{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/",
      "destination": "/BudgetIT/index.html"
    },
    {
      "source": "/app",
      "destination": "/BudgetIT/app.html"
    },
    {
      "source": "/(.*)",
      "destination": "/BudgetIT/$1"
    }
  ]
}
